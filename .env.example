APP_ENV=development
APP_NAME=GCO
APP_VERSION=2.0.0
APP_TIMEZONE=America/Sao_Paulo
API_PREFIX=/api

GATEWAY_PORT=8080

POSTGRES_DB=gco
POSTGRES_USER=gco
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://gco:change-me@postgres:5432/gco
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=20
DB_POOL_RECYCLE=900
API_WORKERS=1
LOG_LEVEL=INFO

REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=128mb

SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
WS_HEARTBEAT_SECONDS=30

GCO_ADMIN_USERNAME=admin
GCO_ADMIN_DISPLAY_NAME=Administrador
GCO_ADMIN_PASSWORD=change-me-with-at-least-8-chars

PANEL_MAX_VISIBLE_CALLS=5
PANEL_CALL_DISPLAY_SECONDS=60

NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_WS_BASE_URL=/ws
